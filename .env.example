# =============================================================
# Phòng Khám Nhi Đồng Dế Mèn — Environment Variables Template
# Copy file này thành .env.local rồi điền giá trị thật.
# KHÔNG commit .env.local lên git.
# =============================================================

# ---------- Firebase (Client SDK - public, OK lộ) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- Firebase Admin SDK (server-side, BẢO MẬT) ----------
# Lấy từ Firebase Console > Project Settings > Service Accounts
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ---------- Gemini API (chatbot LLM) ----------
# Lấy free tại https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---------- Google Sheets API (knowledge base) ----------
# Tạo service account tại https://console.cloud.google.com
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_KB_ID=
GOOGLE_SHEETS_UNANSWERED_ID=

# ---------- Resend (email confirmation + digest) ----------
# Free tier 100 emails/day tại https://resend.com
RESEND_API_KEY=
EMAIL_FROM="Phòng Khám Dế Mèn <noreply@yourdomain.com>"
DOCTOR_EMAIL=

# ---------- Admin ----------
ADMIN_EMAIL=
