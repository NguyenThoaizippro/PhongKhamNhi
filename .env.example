# =============================================================
# Phòng Khám Nhi Đồng Dế Mèn — Environment Variables Template
# Copy file này thành .env.local rồi điền giá trị thật.
# KHÔNG commit .env.local lên git.
# =============================================================

# ---------- Firebase (Client SDK - public, OK lộ) ----------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- Cloudinary (Image Storage — thay Firebase Storage) ----------
# Lấy tại https://console.cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---------- Firebase Admin SDK (server-side, BẢO MẬT) ----------
# Lấy từ Firebase Console > Project Settings > Service Accounts
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ---------- Gemini API (chatbot LLM) ----------
# Lấy free tại https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ---------- Google Sheets API (knowledge base) ----------
# Tạo service account tại https://console.cloud.google.com
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
GOOGLE_SHEETS_KB_ID=

# ---------- Resend (email confirmation + digest) ----------
# Free tier 100 emails/day tại https://resend.com
RESEND_API_KEY=
EMAIL_FROM="Phòng Khám Dế Mèn <noreply@yourdomain.com>"
DOCTOR_EMAIL=

# ---------- Admin ----------
# Email tài khoản admin (bác sĩ) — phải trùng với email đăng nhập Firebase Auth
# Đặt CẢ HAI biến với cùng giá trị:
#   ADMIN_EMAIL              — dùng server-side trong admin-check.ts
#   NEXT_PUBLIC_ADMIN_EMAIL  — dùng client-side để hiển thị badge admin (KHÔNG có quyền thực sự)
ADMIN_EMAIL=
NEXT_PUBLIC_ADMIN_EMAIL=

# ---------- Site URL (cho metadata, sitemap, OG) ----------
# Production: https://phongkhamdemen.vn
# Preview/dev có thể để trống — sẽ dùng default trong layout
NEXT_PUBLIC_SITE_URL=https://phongkhamdemen.vn
